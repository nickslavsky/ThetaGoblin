# Django
DJANGO_SECRET_KEY=change-me-to-a-real-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost

# Database
POSTGRES_USER=thetagoblin
POSTGRES_PASSWORD=thetagoblin
POSTGRES_DB=thetagoblin
DATABASE_URL=postgres://thetagoblin:thetagoblin@db:5432/thetagoblin

# Finnhub API
FINNHUB_TOKEN=your-finnhub-token-here

# Finnhub rate-limit / backoff settings
# Delay between API calls (seconds). Pad above the theoretical 1 req/s limit.
FINNHUB_REQUEST_DELAY=1.2
# Exponential backoff: initial wait (seconds)
BACKOFF_BASE=5
# Exponential backoff: multiplier per retry
BACKOFF_MULTIPLIER=3
# Exponential backoff: max wait ceiling (seconds, default 1 hour)
BACKOFF_MAX=3600
# Exponential backoff: max retries before giving up on a single request
BACKOFF_MAX_RETRIES=10

DOLTHUB_REQUEST_DELAY=2.0
YFINANCE_REQUEST_DELAY=0.5